{
  "name": "selected-projects",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/write-build-info.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/write-build-info.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check": "node scripts/check-content.mjs",
    "postinstall": "node scripts/write-build-info.mjs && simple-git-hooks 2>/dev/null || true",
    "db:migrate": "node --env-file=.env.local scripts/migrate.mjs"
  },
  "simple-git-hooks": {
    "pre-push": "npm run check && npm run build"
  },
  "dependencies": {
    "@libsql/client": "0.17.3",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "16.2.4",
    "@tailwindcss/typography": "0.5.19",
    "@types/mdx": "2.0.13",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "6.12.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
