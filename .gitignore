# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.tpl

# local dev database
dev.db*

# playwright mcp session snapshots
.playwright-mcp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated at build time
/lib/build-info.json

# image originals — local only, compressed copies live in public/
/assets/originals/

# Stray agent/browser screenshots at repo root (real images live in public/)
/*.png
